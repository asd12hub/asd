import java.util.Scanner;

class Product {
    int productID;
    String name;
    double price;

    Product(int id, String n, double p) {
        productID = id;
        name = n;
        price = p;
    }

    void applyDiscount() {
        price = price - (price * 0.05);
    }

    void display() {
        System.out.println(productID + " " + name + " " + price);
    }
}

class Electronics extends Product {
    int warrantyPeriod;

    Electronics(int id, String n, double p, int w) {
        super(id, n, p);
        warrantyPeriod = w;
    }

    void applyDiscount() {
        price = price - (price * 0.10);
    }

    void display() {
        super.display();
        System.out.println("Warranty: " + warrantyPeriod);
    }
}

class Clothing extends Product {
    String size;

    Clothing(int id, String n, double p, String s) {
        super(id, n, p);
        size = s;
    }

    void applyDiscount() {
        price = price - (price * 0.15);
    }

    void display() {
        super.display();
        System.out.println("Size: " + size);
    }
}

class Groceries extends Product {
    String expiryDate;

    Groceries(int id, String n, double p, String e) {
        super(id, n, p);
        expiryDate = e;
    }

    void applyDiscount() {
        price = price - (price * 0.02);
    }

    void display() {
        super.display();
        System.out.println("Expiry: " + expiryDate);
    }
}

class Main {
    public static void main(String args[]) {

        Electronics e = new Electronics(1, "Laptop", 50000, 2);
        Clothing c = new Clothing(2, "TShirt", 1000, "M");
        Groceries g = new Groceries(3, "Milk", 60, "10-04-2026");

        e.applyDiscount();
        c.applyDiscount();
        g.applyDiscount();

        e.display();
        c.display();
        g.display();
    }
}
